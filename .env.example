# Reddit API (create app at https://www.reddit.com/prefs/apps — choose "script" type)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=social-poster/1.0 by u/YOUR_USERNAME

# X/Twitter API (https://developer.x.com/en/portal/dashboard — Free tier)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
